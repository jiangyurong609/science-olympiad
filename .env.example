ENVIRONMENT=development
DATABASE_URL=sqlite:///./science_olympiad.db
JWT_SECRET=replace-with-a-long-random-secret
ALLOWED_CRAWL_DOMAINS=nasa.gov,noaa.gov,usgs.gov,nih.gov,cdc.gov,epa.gov,nist.gov
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMAIL_DELIVERY_PROVIDER=disabled
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
PUBLIC_APP_URL=http://localhost:8000
TUTOR_DAILY_MESSAGES=50
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
WORKER_POLL_SECONDS=2
