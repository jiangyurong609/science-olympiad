# Large generated specimen imagery — regenerated by scripts/fetch_specimen_images.py
# and bundled into the container via .gcloudignore (not .gitignore), so excluding
# them here keeps the git repo small without affecting deploys. manifest.json stays.
app/static/media/**/*.jpg
app/static/media/**/*.jpeg
app/static/media/**/*.png
app/static/media/**/*.webp
